<h1 class="mb-4">Dashboard</h1>

<div class="row">
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">Low Stock Products</h5>
      </div>
      <div class="card-body">
        <% if @low_stock_products.any? %>
          <table class="table table-sm table-hover mb-0">
            <thead>
              <tr>
                <th>SKU</th>
                <th>Name</th>
                <th class="text-end">Current</th>
                <th class="text-end">Minimum</th>
              </tr>
            </thead>
            <tbody>
              <% @low_stock_products.each do |product| %>
                <tr>
                  <td><%= product.sku %></td>
                  <td><%= link_to product.name, product %></td>
                  <td class="text-end text-danger fw-bold"><%= product.total_quantity %></td>
                  <td class="text-end"><%= product.minimum_quantity %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-muted mb-0">All products are sufficiently stocked.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header bg-info text-white">
        <h5 class="card-title mb-0">Recent Stock Movements</h5>
      </div>
      <div class="card-body">
        <% if @recent_movements.any? %>
          <table class="table table-sm table-hover mb-0">
            <thead>
              <tr>
                <th>Time</th>
                <th>Type</th>
                <th>Product</th>
                <th class="text-end">Qty</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_movements.each do |movement| %>
                <tr>
                  <td><%= movement.created_at.strftime("%m/%d %H:%M") %></td>
                  <td>
                    <span class="badge bg-<%= movement.inbound? ? 'success' : 'danger' %>">
                      <%= movement.operation_type %>
                    </span>
                  </td>
                  <td><%= link_to movement.product.name, movement %></td>
                  <td class="text-end"><%= movement.quantity %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-muted mb-0">No stock movements recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="d-flex gap-2">
      <%= link_to "New Stock Movement", new_stock_movement_path, class: "btn btn-primary" %>
      <%= link_to "New Product", new_product_path, class: "btn btn-outline-secondary" %>
      <%= link_to "New Warehouse", new_warehouse_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>

<h1 class="mb-4">Inventory</h1>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Product</th>
      <th>SKU</th>
      <th>Warehouse</th>
      <th class="text-end">Quantity</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @inventories.each do |inventory| %>
      <tr>
        <td><%= link_to inventory.product.name, inventory.product %></td>
        <td><code><%= inventory.product.sku %></code></td>
        <td><%= link_to inventory.warehouse.name, inventory.warehouse %></td>
        <td class="text-end"><%= inventory.quantity %></td>
        <td>
          <% if inventory.quantity <= inventory.product.minimum_quantity %>
            <span class="badge bg-danger">Low</span>
          <% else %>
            <span class="badge bg-success">OK</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @inventories %>

<%= render "shared/form_errors", resource: product %>

<%= form_with(model: product, class: "mb-3") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :sku, "SKU", class: "form-label" %>
    <%= f.text_field :sku, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :minimum_quantity, class: "form-label" %>
    <%= f.number_field :minimum_quantity, class: "form-control", min: 0 %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", products_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

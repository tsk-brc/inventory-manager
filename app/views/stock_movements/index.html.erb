<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Stock Movements</h1>
  <%= link_to "New Movement", new_stock_movement_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Type</th>
      <th>Product</th>
      <th>Warehouse</th>
      <th class="text-end">Quantity</th>
      <th>By</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @stock_movements.each do |movement| %>
      <tr>
        <td><%= movement.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td>
          <span class="badge bg-<%= movement.inbound? ? 'success' : 'danger' %>">
            <%= movement.operation_type %>
          </span>
        </td>
        <td><%= link_to movement.product.name, movement.product %></td>
        <td><%= link_to movement.warehouse.name, movement.warehouse %></td>
        <td class="text-end"><%= movement.quantity %></td>
        <td><%= movement.user.email %></td>
        <td class="text-end">
          <%= link_to "Detail", movement, class: "btn btn-sm btn-outline-secondary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @stock_movements %>

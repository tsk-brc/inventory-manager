<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Warehouses</h1>
  <%= link_to "New Warehouse", new_warehouse_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Address</th>
      <th class="text-end">Products</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @warehouses.each do |warehouse| %>
      <tr>
        <td><%= link_to warehouse.name, warehouse %></td>
        <td><%= truncate(warehouse.address.to_s, length: 60) %></td>
        <td class="text-end"><%= warehouse.inventories.size %></td>
        <td class="text-end">
          <%= link_to "Edit", edit_warehouse_path(warehouse), class: "btn btn-sm btn-outline-secondary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @warehouses %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @warehouse.name %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_warehouse_path(@warehouse), class: "btn btn-outline-secondary" %>
    <%= button_to "Delete", @warehouse, method: :delete, class: "btn btn-outline-danger",
        data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <dl class="row">
      <dt class="col-sm-4">Address</dt>
      <dd class="col-sm-8"><%= @warehouse.address.presence || "—" %></dd>
    </dl>
  </div>
</div>

<% if @inventories.any? %>
  <h4>Inventory</h4>
  <table class="table table-sm table-striped mb-4">
    <thead>
      <tr>
        <th>Product</th>
        <th>SKU</th>
        <th class="text-end">Quantity</th>
      </tr>
    </thead>
    <tbody>
      <% @inventories.each do |inventory| %>
        <tr>
          <td><%= link_to inventory.product.name, inventory.product %></td>
          <td><code><%= inventory.product.sku %></code></td>
          <td class="text-end"><%= inventory.quantity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @recent_movements.any? %>
  <h4>Recent Movements</h4>
  <table class="table table-sm table-striped">
    <thead>
      <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Product</th>
        <th class="text-end">Quantity</th>
        <th>By</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_movements.each do |movement| %>
        <tr>
          <td><%= movement.created_at.strftime("%Y-%m-%d %H:%M") %></td>
          <td>
            <span class="badge bg-<%= movement.inbound? ? 'success' : 'danger' %>">
              <%= movement.operation_type %>
            </span>
          </td>
          <td><%= movement.product.name %></td>
          <td class="text-end"><%= movement.quantity %></td>
          <td><%= movement.user.email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
